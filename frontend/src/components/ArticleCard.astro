---
const { id, title, content } = Astro.props;
---

<a href={`/articles/${id}`} class="card">
  <h3>{title}</h3>
  <p>{content}</p>
</a>

<style>
  .card {
    display: block;
    border: 1px solid #ddd;
    padding: 16px;
    margin-bottom: 12px;
    border-radius: 8px;
    text-decoration: none;
    color: black;
  }

  .card:hover {
    background: #f5f5f5;
  }
</style>
